<div class="flex flex-col items-center justify-center h-full">
  <p class="text-base-content/30 text-xs tracking-[0.4em] uppercase mb-14">
    — where will you venture? —
  </p>

  <div class="flex flex-wrap justify-center gap-10">
    <%= for %{href: href, title: title, description: description} <- @destinations do %>
      <.destination_card href={href} title={title} description={description} />
    <% end %>
  </div>
</div>
